# Copied by docker-compose via ${VAR} interpolation. Generate a real secret with:
#   openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Only needed when running the `worker` profile — the UUID of the project it should serve.
# Create a project through the UI first, then copy its id from the URL or API response.
WORKER_PROJECT_ID=
WORKER_CONCURRENCY=10
